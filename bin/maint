#!/bin/bash
# Run system maintenance, stream to stdout, then summarize locally with apfel.
set -o pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
LOG="$(mktemp -t maint.XXXXXX)"
trap 'rm -f "$LOG"' EXIT

"$BIN_DIR/maintenance" "$@" 2>&1 | tee "$LOG"
status=${PIPESTATUS[0]}

echo
echo "── Summary ──"
# apfel enforces the real 4096-token budget itself and fails cleanly on overflow,
# so we don't second-guess it with a char heuristic. The full log is printed
# above, so a failed summary degrades to a one-line notice.
apfel -q --max-tokens 256 \
  -s "Summarize a system maintenance run. Terse bullets; call out failures, warnings, or anything unusual." \
  -f "$LOG" "Summarize:" ||
  echo "(local summary unavailable -- see full output above)"

exit "$status"
