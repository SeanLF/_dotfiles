#!/bin/bash
# System maintenance — run periodically to keep packages updated.
# Pass --check to preview what *would* be upgraded without changing anything.
set -e

CHECK_ONLY=false
for arg in "$@"; do
  case "$arg" in
    --check | -n) CHECK_ONLY=true ;;
    -h | --help)
      echo "Usage: $0 [--check]"
      exit 0
      ;;
    *)
      echo "unknown argument: $arg" >&2
      echo "Usage: $0 [--check]" >&2
      exit 2
      ;;
  esac
done

# Activate mise so tools it manages (tldr, gh, etc.) are on PATH for this script.
# Maintenance runs non-interactively, so mise's shell prompt hooks don't fire;
# `mise env` emits the equivalent exports directly. Guarded so a mise hiccup
# doesn't abort the whole run under `set -e`.
if command -v mise &>/dev/null; then
  eval "$(mise env -s bash 2>/dev/null)" || true
fi

if [[ -t 1 ]]; then
  bold='\033[1m' dim='\033[2m'
  red='\033[31m' green='\033[32m' yellow='\033[33m' blue='\033[34m'
  reset='\033[0m'
else
  bold='' dim='' red='' green='' yellow='' blue='' reset=''
fi

DOTFILES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
BREWFILE="$DOTFILES_DIR/Brewfile"
failures=()

step() { echo -e "${bold}${blue}==> $1${reset}"; }
info() { echo -e "${dim}$1${reset}"; }
ok() { echo -e "${green}$1${reset}"; }
warn() {
  echo -e "${yellow}$1${reset}" >&2
  failures+=("$1")
}

# Run a command and convert non-zero exit into a warning (not a hard fail).
# Individual step failures shouldn't abort the whole maintenance run.
try() { "$@" || warn "$* failed"; }

step_homebrew() {
  step "Homebrew"
  try brew update
  if $CHECK_ONLY; then
    brew outdated || true
    brew outdated --cask --greedy-auto-updates || true
  else
    try brew upgrade
    try brew upgrade --cask
    try brew autoremove
    try brew cleanup
  fi
}

step_appstore() {
  step "App Store"
  if $CHECK_ONLY; then
    mas outdated || true
  else
    try mas upgrade
  fi
}

# Workaround: `claude update` downloads the full binary (~200MB) even when
# already up-to-date. Compare versions first to skip the download.
# Claude Code also auto-upgrades while running; this just prefetches before
# the next session starts. https://github.com/anthropics/claude-code/issues/20808
step_claude_code() {
  step "Claude Code"
  local local_ver dist_url remote_ver
  local_ver="$(claude --version 2>/dev/null | awk '{print $1}' || true)"
  dist_url="$(curl -sI https://claude.ai/install.sh 2>/dev/null |
    grep -i '^location:' | tr -d '\r' |
    sed 's/^[Ll]ocation: //; s|/bootstrap\.sh$||')"
  remote_ver="$(curl -sf "$dist_url/latest" 2>/dev/null || true)"

  if [[ -z "$remote_ver" ]]; then
    warn "could not check latest Claude Code version"
    $CHECK_ONLY || try claude update
  elif [[ "$local_ver" == "$remote_ver" ]]; then
    ok "Claude Code is already up to date ($local_ver)"
  else
    info "Claude Code $local_ver -> $remote_ver"
    $CHECK_ONLY || try claude update
  fi
}

# NextDNS is installed via Homebrew, so `brew upgrade` above already handles it.
# The CLI's own `nextdns upgrade` subcommand can't overwrite a brew-managed
# binary ("Cannot detect running environment") — brew owns the install path.

step_mise() {
  step "mise"
  # Scope GITHUB_TOKEN to just this step so it doesn't leak to other tools.
  # Without it, mise's "latest" resolution hits unauthenticated rate limits.
  local gh_token=""
  if command -v gh &>/dev/null && gh auth status &>/dev/null; then
    gh_token="$(gh auth token)"
  fi
  if $CHECK_ONLY; then
    GITHUB_TOKEN="$gh_token" mise outdated || true
  else
    GITHUB_TOKEN="$gh_token" try mise upgrade
    try mise prune --yes
  fi
}

step_uv() {
  step "uv tools"
  if $CHECK_ONLY; then
    uv tool list --outdated 2>/dev/null || uv tool list || true
  else
    try uv tool upgrade --all
  fi
}

# Default gems shipped with mise-managed Ruby drift behind upstream and
# aren't refreshed by `mise upgrade`.
step_gems() {
  step "Ruby gems"
  command -v gem &>/dev/null || {
    info "gem not found, skipping"
    return
  }
  if $CHECK_ONLY; then
    gem outdated || true
  else
    try gem update
  fi
}

# rustup is bootstrapped manually (not via brew or mise). mise's `rust` plugin
# delegates to rustup, so `mise upgrade` installs the latest stable toolchain
# through rustup, but rustup itself, its other toolchains, and stale
# components only refresh via `rustup self update` / `rustup update`.
step_rustup() {
  step "rustup"
  command -v rustup &>/dev/null || {
    info "rustup not installed, skipping"
    return
  }
  if $CHECK_ONLY; then
    rustup check || true
  else
    try rustup self update
    try rustup update
  fi
}

step_tldr() {
  step "tldr"
  $CHECK_ONLY || try tldr --update
}

step_brewfile() {
  step "Brewfile"
  if $CHECK_ONLY; then
    info "(skipped in --check mode)"
  elif [[ -f "$BREWFILE" ]]; then
    try brew bundle dump --file="$BREWFILE" --force --describe
    ok "Brewfile updated"
  else
    warn "Brewfile not found at $BREWFILE"
  fi
}

step_macos() {
  step "macOS updates"
  softwareupdate --list 2>&1 | grep -v "^Software Update Tool" || true
}

# Bail early if offline
if ! online -q 5; then
  echo -e "${red}No network connectivity — skipping maintenance${reset}"
  exit 1
fi

step_homebrew
step_appstore
step_claude_code
step_mise
step_gems
step_rustup
step_uv
step_tldr
step_brewfile
step_macos

echo ""
if [[ ${#failures[@]} -gt 0 ]]; then
  echo -e "${red}Finished with ${#failures[@]} warning(s):${reset}"
  for f in "${failures[@]}"; do echo -e "  ${yellow}- $f${reset}"; done
  exit 1
else
  ok "Done -- all clear!"
fi
